#!/bin/bash

# Function to check if dotnet-outdated is installed
check_dotnet_outdated_installed() {
    if ! dotnet tool list -g | grep -q 'dotnet-outdated'; then
        echo "dotnet-outdated is not installed. Installing it now..."
        dotnet tool install --global dotnet-outdated-tool
    fi
}

# Initialize variables
update_packages=false
include_major=false

# Parse command-line arguments
while getopts "um" opt; do
    case $opt in
        u)
            update_packages=true
            ;;
        m)
            update_packages=true
            include_major=true
            ;;
        *)
            echo "Invalid option: -$OPTARG" >&2
            exit 1
            ;;
    esac
done

# Directory holding the TypeScript VS Code extension
vscode_ext_dir="$PWD/src/DependinatorVsCode"

# Check if dotnet-outdated is installed
check_dotnet_outdated_installed

# ---------------------------------------------------------------------------------
# .NET packages
# ---------------------------------------------------------------------------------
if [ "$update_packages" = true ]; then
    if [ "$include_major" = true ]; then
        echo "Upgrading all packages (including major) in '$PWD' ..."
        dotnet outdated "$projectFile" --upgrade
    else
        echo "Upgrading all non-major packages in '$PWD' ..."
        dotnet outdated "$projectFile" --upgrade --version-lock Major
    fi
fi

echo
echo "================================================================================="
echo "Listing all outdated packages in $PWD"
dotnet outdated
echo
echo "================================================================================="
echo "Checking for vulnerable packages in $PWD"
dotnet list package --vulnerable

# ---------------------------------------------------------------------------------
# TypeScript packages (VS Code extension)
# ---------------------------------------------------------------------------------
if [ -f "$vscode_ext_dir/package.json" ]; then
    echo
    echo "================================================================================="
    echo "TypeScript (VS Code extension) packages in $vscode_ext_dir"

    if [ "$update_packages" = true ]; then
        if [ "$include_major" = true ]; then
            echo "Upgrading all npm packages (including major) ..."
            # npm-check-updates rewrites package.json ranges to the latest versions
            (cd "$vscode_ext_dir" && npx --yes npm-check-updates -u && npm install)
        else
            echo "Upgrading all non-major npm packages (within semver ranges) ..."
            (cd "$vscode_ext_dir" && npm update)
        fi
    fi

    echo
    echo "Listing all outdated npm packages"
    (cd "$vscode_ext_dir" && npm outdated)
    echo
    echo "Checking for vulnerable npm packages"
    (cd "$vscode_ext_dir" && npm audit)
fi

echo
echo "---------------------------------------------------------------------------------"
echo "Use option '-u' to update non-major outdated packages"
echo "Use option '-m' to update all outdated packages including major versions"
echo