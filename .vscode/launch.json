{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "WebServer",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "start sync services",
            "program": "${workspaceFolder}/src/Dependinator.Web/bin/Debug/net10.0/Dependinator.Web.dll",
            "args": [],
            "cwd": "${workspaceFolder}/src/Dependinator.Web",
            "stopAtEntry": false,
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            },
            "sourceFileMap": {
                "/Views": "${workspaceFolder}/src/Dependinator.Web/Views"
            },
            "dotnetRunMessages": true,
            "console": "internalConsole"
        },
        {
            "name": "VSCodeExt",
            "type": "extensionHost",
            "request": "launch",
            "preLaunchTask": "Dependinator: Prepare and Compile Extension",
            "args": [
                "--new-window",
                "${workspaceFolder}/debug.code-workspace",
                "--disable-extension",
                "github.copilot-chat",
                "--disable-extension",
                "openai.chatgpt",
                "--extensionDevelopmentPath=${workspaceFolder}/src/DependinatorVsCode"
            ]
        }
    ],
    // "compounds": [
    //     {
    //         "name": "Wasm/Server",
    //         "configurations": [
    //             "Attach to .NET Functions",
    //             "Launch and Debug Standalone Blazor WebAssembly App"
    //         ]
    //     }
    // ]
}