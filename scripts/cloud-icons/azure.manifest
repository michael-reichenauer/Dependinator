# Curated Azure icons: "<source-key> = <Target-Name>" where the source key is the dashed name
# after "-icon-service-" in the official package (numeric file prefixes change per release).
# Import via ./scripts/import-icons; see scripts/import-cloud-icons.mjs for the package url/version.

