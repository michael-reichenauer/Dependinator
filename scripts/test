#!/bin/bash
# Run the full test suite: the unit tests (Api / Core / Roslyn / UI) first, then the
# Playwright e2e UI tests. Both always run; the script exits non-zero if either fails.
# Any arguments are forwarded to ./scripts/e2e, e.g.:
#
#   ./scripts/test            unit tests, then e2e (chromium)
#   ./scripts/test -s -t      ... and run the e2e part with the cloud-sync stack + tracing
#   ./scripts/test -a         ... and run the e2e part on all browsers
#
# Note: the e2e part needs port 5000 free (it starts the app in test mode itself), so
# stop ./scripts/watch first — see ./scripts/e2e.
set -uo pipefail
cd "$(dirname "$0")/.."

result=0

echo "=== Unit tests (dotnet test Dependinator.sln — e2e tests skip here) ==="
# The e2e tests skip here by design; hide the per-test "Skipped ..."/"[SKIP]" lines so
# real failures stand out (the "Skipped: N" count stays in the summary line). Failure
# output is unaffected; pipefail keeps dotnet test's exit code through the pipe.
if ! dotnet test Dependinator.sln 2>&1 | grep -vE '^\s+Skipped |\[SKIP\]$'; then
    result=1
    echo "Unit tests FAILED."
fi

echo ""
echo "=== E2E tests (./scripts/e2e $*) ==="
if ! ./scripts/e2e "$@"; then
    result=1
    echo "E2E tests FAILED."
fi

echo ""
if [[ "$result" -eq 0 ]]; then
    echo "All tests passed."
else
    echo "Some tests FAILED (see above)."
fi
exit "$result"
