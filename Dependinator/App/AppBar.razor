@using Dependinator.Core
@using Dependinator.Shared.CloudSync
@inject ICanvasService srv
@inject IAppCloudSyncService appCloudSyncService
@inject ISnackbar snackbar
@inject Dependinator.Models.IModelService modelService
@inject IApplicationEvents applicationEvents
@implements IDisposable

<MudButtonGroup Color="Color.Tertiary" Size="Size.Small" Variant="Variant.Filled" Style="@CssPosition">
    <MudMenu Icon="@Icons.Material.Outlined.Menu" IconColor="Color.Secondary" Dense="true" Class="ml-n3"
             AnchorOrigin="Origin.BottomCenter">
        <MudMenuItem IconColor="Color.Secondary" Icon="@Icons.Material.Outlined.Undo"
                     Disabled="@(!modelService.CanUndo)" OnClick="modelService.Undo">
            Undo
        </MudMenuItem>

        <MudMenuItem IconColor="Color.Secondary" Icon="@Icons.Material.Outlined.Redo"
                     Disabled="@(!modelService.CanRedo)" OnClick="modelService.Redo">
            Redo
        </MudMenuItem>

        <MudMenuItem IconColor="Color.Secondary" Icon="@Icons.Material.Outlined.FitScreen" OnClick="srv.PanZoomToFit">
            Fit to Screen
        </MudMenuItem>

        <MudMenuItem IconColor="Color.Secondary" Icon="@Icons.Material.Outlined.Refresh" OnClick="srv.Refresh">
            Refresh
        </MudMenuItem>

        <MudDivider />

        <MudMenuItem IconColor="Color.Error" Icon="@Icons.Material.Outlined.DeveloperBoardOff" OnClick="OnRemove">
            Reset Model
        </MudMenuItem>

        <MudDivider />
        @{
            string? currentPath = RecentModelPaths.Count > 0 ? RecentModelPaths[0] : null;
        }
        @foreach (string path in RecentModelPaths)
        {
            bool isCurrent = path == currentPath;
            <MudMenuItem IconColor="@(isCurrent? Color.Secondary: Color.Default)" Icon="@Icons.Material.Outlined.Schema"
                         Style="@(isCurrent ? "color: var(--mud-palette-primary);" : null)" OnClick="() => srv.LoadAsync(path)">
                @Path.GetFileNameWithoutExtension(path)
            </MudMenuItem>
        }

        @if (appCloudSyncService.IsAvailable)
        {
            <MudDivider />

            <MudMenuItem Disabled="true" Icon="@Icons.Material.Outlined.Cloud">
                @CloudStatusText
            </MudMenuItem>
            <MudMenuItem Disabled="true" Icon="@SyncStatusIcon">
                @SyncStatusText
            </MudMenuItem>

            @if (AuthState.IsAuthenticated)
            {
                @if (CloudModels.Count > 0)
                {
                    <MudMenuItem Disabled="true" Icon="@Icons.Material.Outlined.CloudQueue">
                        Cloud Models
                    </MudMenuItem>
                    @foreach (global::Shared.CloudModelMetadata cloudModel in CloudModels)
                    {
                        bool isCurrentCloudModel = string.Equals(
                            cloudModel.NormalizedPath,
                            appCloudSyncService.CurrentNormalizedModelPath,
                            StringComparison.OrdinalIgnoreCase
                        );
                        <MudMenuItem IconColor="@(isCurrentCloudModel? Color.Secondary: Color.Default)"
                                     Icon="@Icons.Material.Outlined.Schema"
                                     Style="@(isCurrentCloudModel ? "color: var(--mud-palette-primary);" : null)"
                                     OnClick="() => LoadCloudModelAsync(cloudModel)">
                            @Path.GetFileNameWithoutExtension(cloudModel.NormalizedPath)
                        </MudMenuItem>
                    }
                }
                <MudMenuItem IconColor="Color.Secondary" Icon="@Icons.Material.Outlined.CloudUpload" OnClick="SyncUpAsync">
                    Sync Up
                </MudMenuItem>
                <MudMenuItem IconColor="Color.Secondary" Icon="@Icons.Material.Outlined.CloudDownload" OnClick="SyncDownAsync">
                    Sync Down
                </MudMenuItem>
                <MudMenuItem IconColor="Color.Secondary" Icon="@Icons.Material.Outlined.Logout" OnClick="LogoutAsync">
                    Logout
                </MudMenuItem>
            }
            else
            {
                <MudMenuItem IconColor="Color.Secondary" Icon="@Icons.Material.Outlined.Login" OnClick="LoginAsync">
                    Login
                </MudMenuItem>
            }
        }

        <MudDivider />
        <MudMenuItem IconColor="Color.Secondary" Icon="@Icons.Material.Outlined.Info" OnClick="ShowAbout">
            About
        </MudMenuItem>
    </MudMenu>

    <MudIconButton Icon="@CloudIcon" Color="@CloudIconColor" Disabled="@(!appCloudSyncService.IsAvailable)"
                   title="@CloudStatusText" OnClick="ToggleCloudAuthAsync" />

    <MudHidden Breakpoint="Breakpoint.SmAndDown">
        @if (modelService.CanUndo)
        {
            <MudIconButton Icon="@Icons.Material.Outlined.Undo" OnClick="modelService.Undo" />
        }
        else
        {
            <MudIconButton Icon="@Icons.Material.Outlined.Undo" Color="Color.Inherit" OnClick="modelService.Undo" />
        }

        @if (modelService.CanRedo)
        {
            <MudIconButton Icon="@Icons.Material.Outlined.Redo" OnClick="modelService.Redo" />
        }
        else
        {
            <MudIconButton Icon="@Icons.Material.Outlined.Redo" Color="Color.Inherit" OnClick="modelService.Redo" />
        }

        <MudIconButton Icon="@Icons.Material.Outlined.Refresh" OnClick="srv.Refresh" />
    </MudHidden>

</MudButtonGroup>

<MudMessageBox @ref="mbox" Title="Reset Model" CancelText="Cancel">
    <MessageContent>
        <MudText>Do you want to reset model?</MudText>
        <MudText Typo="Typo.body2">Note: Layout of all nodes and sub-nodes will be reset.</MudText>
    </MessageContent>
    <YesButton>
        <MudButton Variant="Variant.Filled" Color="Color.Error" StartIcon="@Icons.Material.Filled.DeveloperBoardOff">
            Reset
        </MudButton>
    </YesButton>
</MudMessageBox>

<MudMessageBox @ref="aboutBox" Title="About Dependinator" YesText="Close">
    <MessageContent>
        <MudText Typo="Typo.body1">Version: @Build.Version</MudText>
        <MudText Typo="Typo.body1">Commit: @Build.CommitSid</MudText>
        <MudText Typo="Typo.body1">Build Time: @Build.Time</MudText>
    </MessageContent>
</MudMessageBox>

<MudMessageBox @ref="syncDownBox" Title="Replace Local Cached Model" CancelText="Cancel">
    <MessageContent>
        <MudText>Download the cloud copy and overwrite the local cached model?</MudText>
        <MudText Typo="Typo.body2">The current local cached layout data will be replaced.</MudText>
    </MessageContent>
    <YesButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.CloudDownload">
            Replace
        </MudButton>
    </YesButton>
</MudMessageBox>

@code {
    MudMessageBox mbox { get; set; } = null!;
    MudMessageBox aboutBox { get; set; } = null!;
    MudMessageBox syncDownBox { get; set; } = null!;

    record CloudIconInfo(string Icon, MudBlazor.Color Color);
    static readonly CloudIconInfo NotAvailable = new(Icons.Material.Outlined.CloudOff, Color.Inherit);
    static readonly CloudIconInfo NotAuthenticated = new(Icons.Material.Outlined.CloudQueue, Color.Inherit);
    static readonly CloudIconInfo HasLocalChanges = new(Icons.Material.Outlined.CloudUpload, Color.Info);
    // static readonly CloudIconInfo HasRemoteChanges = new(Icons.Material.Outlined.CloudDownload, Color.Warning);
    static readonly CloudIconInfo IsSynced = new(Icons.Material.Filled.CloudDone, Color.Success);

    IReadOnlyList<string> RecentModelPaths => srv.RecentModelPaths;
    global::Shared.CloudAuthState AuthState => appCloudSyncService.AuthState;
    IReadOnlyList<global::Shared.CloudModelMetadata> CloudModels => appCloudSyncService.CloudModels;
    string CssPosition => $"position:fixed;left:{15}px; top:{3}px;";
    string CloudStatusText =>
        !appCloudSyncService.IsAvailable
            ? "Cloud sync unavailable"
            : AuthState.IsAuthenticated
                ? $"Cloud signed in as {AuthState.User?.Email ?? AuthState.User?.UserId}"
                : "Cloud not signed in";
    string SyncStatusText =>
        appCloudSyncService.LatestSync switch
        {
            { } latestSync =>
                $"Sync: {GetSyncDirectionText(latestSync.Direction)} {latestSync.Utc.LocalDateTime:g} - {(appCloudSyncService.HasLocalChangesSinceLastSync ? "local changes" : "in sync")}",
            null when string.IsNullOrWhiteSpace(modelService.ModelPath) => "Sync: model not loaded",
            _ => "Sync: no sync recorded",
        };
    string SyncStatusIcon =>
        appCloudSyncService.LatestSync?.Direction switch
        {
            CloudSyncDirection.Up => Icons.Material.Outlined.CloudUpload,
            CloudSyncDirection.Down => Icons.Material.Outlined.CloudDownload,
            _ => Icons.Material.Outlined.CloudQueue,
        };

    string CloudIcon => GetCloudIconInfo().Icon;
    MudBlazor.Color CloudIconColor => GetCloudIconInfo().Color;

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();

        applicationEvents.UIStateChanged += OnUiStateChanged;
        appCloudSyncService.Changed += OnUiStateChanged;

        if (!Try(out var error, await appCloudSyncService.InitializeAsync()))
            snackbar.Add(error.ErrorMessage, Severity.Warning);
    }

    CloudIconInfo GetCloudIconInfo() => appCloudSyncService.GetCloudSyncState() switch
    {
        CloudSyncState.NotAvailable => NotAvailable,
        CloudSyncState.NotAuthenticated => NotAuthenticated,
        CloudSyncState.HasLocalChanges => HasLocalChanges,
        //CloudSyncState.HasRemoteChanges => HasRemoteChanges,
        CloudSyncState.IsSynced => IsSynced,
        _ => NotAvailable
    };

    public void Dispose()
    {
        applicationEvents.UIStateChanged -= OnUiStateChanged;
        appCloudSyncService.Changed -= OnUiStateChanged;
    }

    async Task ToggleCloudAuthAsync()
    {
        var state = appCloudSyncService.GetCloudSyncState();

        if (state is CloudSyncState.NotAvailable)
            return;

        if (state is CloudSyncState.NotAuthenticated) await LoginAsync();
        if (state is CloudSyncState.HasLocalChanges) await SyncUpAsync();
    }

    async Task LoginAsync()
    {
        if (!Try(out var error, await appCloudSyncService.LoginAsync()))
        {
            snackbar.Add(error.ErrorMessage, Severity.Error);
            return;
        }

        snackbar.Add($"Cloud sync is enabled.", Severity.Success);
    }

    async Task SyncUpAsync()
    {
        if (!Try(out var metadata, out var error, await appCloudSyncService.SyncUpAsync()))
        {
            snackbar.Add(error.ErrorMessage, Severity.Error);
            return;
        }
    }

    async Task LogoutAsync()
    {
        if (!Try(out var error, await appCloudSyncService.LogoutAsync()))
        {
            snackbar.Add(error.ErrorMessage, Severity.Error);
            return;
        }

        snackbar.Add($"Cloud sync is disabled.", Severity.Info);
    }

    async Task SyncDownAsync()
    {
        if (await syncDownBox.ShowAsync() != true)
            return;

        if (string.IsNullOrWhiteSpace(modelService.ModelPath))
        {
            snackbar.Add("Model is not loaded.", Severity.Warning);
            return;
        }

        if (!Try(out var modelInfo, out var error, await appCloudSyncService.SyncDownAsync()))
        {
            snackbar.Add(error.ErrorMessage, Severity.Error);
            return;
        }

        snackbar.Add($"Loaded cloud model for {Path.GetFileNameWithoutExtension(modelInfo.Path)}.", Severity.Success);
    }

    async Task LoadCloudModelAsync(global::Shared.CloudModelMetadata cloudModel)
    {
        if (!Try(out _, out var error, await appCloudSyncService.LoadCloudModelAsync(cloudModel)))
        {
            snackbar.Add(error.ErrorMessage, Severity.Error);
            return;
        }

        snackbar.Add(
            $"Loaded cloud model for {Path.GetFileNameWithoutExtension(cloudModel.NormalizedPath)}.",
            Severity.Success
        );
    }

    async Task OnRemove()
    {
        if (await mbox.ShowAsync() != true)
            return;

        srv.Remove();
    }

    async Task ShowAbout()
    {
        await aboutBox.ShowAsync();
    }

    void OnUiStateChanged() => InvokeAsync(StateHasChanged);

    static string GetSyncDirectionText(CloudSyncDirection direction) =>
        direction switch
        {
            CloudSyncDirection.Up => "up",
            CloudSyncDirection.Down => "down",
            _ => "unknown",
        };
}