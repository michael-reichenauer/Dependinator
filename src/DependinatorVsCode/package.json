{
    "name": "dependinator",
    "displayName": "Dependinator",
    "description": "Dependinator visualizes code structure and dependencies as an interactive, navigable map, making complex architectures easier to understand, analyze, and refactor.",
    "version": "0.5.52",
    "publisher": "michaelreichenauer",
    "license": "MIT",
    "repository": "https://github.com/michael-reichenauer/Dependinator",
    "icon": "media/icon-192.png",
    "engines": {
        "vscode": "^1.84.0"
    },
    "categories": [
        "Visualization"
    ],
    "extensionKind": [
        "workspace"
    ],
    "activationEvents": [],
    "main": "./dist/node/extension.js",
    "browser": "./dist/web/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "dependinator.open",
                "title": "Dependinator: Open",
                "icon": {
                    "light": "resources/icon-tree-dark.svg",
                    "dark": "resources/icon-tree-light.svg"
                }
            },
            {
                "command": "dependinator.installInDevContainer",
                "title": "Dependinator: Install in Dev Container"
            }
        ],
        "menus": {
            "editor/title": [
                {
                    "command": "dependinator.open",
                    "group": "navigation",
                    "when": "true"
                }
            ]
        },
        "configuration": {
            "title": "Dependinator",
            "properties": {
                "dependinator.cloudSync.baseUrl": {
                    "type": "string",
                    "enum": [
                        "https://dependinator.com",
                        "https://polite-island-0e6a6eb03-dev.westeurope.4.azurestaticapps.net",
                        "http://localhost:4280",
                        "http://127.0.0.1:5000",
                        "http://127.0.0.1:7071"
                    ],
                    "enumItemLabels": [
                        "Production",
                        "Dev",
                        "Local (SWA CLI)",
                        "Local (run)",
                        "Local (watch)"
                    ],
                    "enumDescriptions": [
                        "Uses the production Dependinator cloud sync service.",
                        "Uses the deployed development Azure Static Web Apps environment.",
                        "Uses the local SWA CLI on port 4280.",
                        "Uses run (SWA CLI on port 5000, proxies API to Functions).",
                        "Uses watch (Functions host directly on port 7071)."
                    ],
                    "default": "https://dependinator.com",
                    "description": "Base URL for the Dependinator cloud sync API. Sign-in is handled separately by the extension."
                },
                "dependinator.cloudSync.clerkAccountsUrl": {
                    "type": "string",
                    "default": "",
                    "description": "Clerk accounts URL used for cloud sync sign-in. Leave empty to use the built-in production Clerk instance."
                },
                "dependinator.cloudSync.clerkPublishableKey": {
                    "type": "string",
                    "default": "",
                    "description": "Clerk publishable key used for cloud sync sign-in. Leave empty to use the built-in production key."
                },
                "dependinator.autoRefresh.enabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "Automatically refresh the diagram when workspace source files change."
                },
                "dependinator.autoRefresh.delaySeconds": {
                    "type": "number",
                    "default": 3,
                    "minimum": 1,
                    "description": "Delay in seconds after the last source file change before the diagram is refreshed."
                }
            }
        }
    },
    "scripts": {
        "check-types": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
        "compile": "npm run check-types && node esbuild.js",
        "watch": "node esbuild.js --watch",
        "prepare:wasm": "bash scripts/prepare-wasm.sh",
        "prepare:server": "bash scripts/prepare-server.sh",
        "build:extension": "npm run prepare:wasm && npm run prepare:server && npm run check-types && node esbuild.js --production",
        "package": "DEPENDINATOR_ALL_SERVERS=1 vsce package --out dependinator.vsix",
        "install:vsix": "code --install-extension dependinator.vsix --force",
        "package:linux-x64": "VSCODE_TARGET=linux-x64 vsce package --target linux-x64",
        "package:linux-arm64": "VSCODE_TARGET=linux-arm64 vsce package --target linux-arm64",
        "package:win32-x64": "VSCODE_TARGET=win32-x64 vsce package --target win32-x64",
        "package:win32-arm64": "VSCODE_TARGET=win32-arm64 vsce package --target win32-arm64",
        "package:darwin-x64": "VSCODE_TARGET=darwin-x64 vsce package --target darwin-x64",
        "package:darwin-arm64": "VSCODE_TARGET=darwin-arm64 vsce package --target darwin-arm64",
        "package:all-platforms": "npm run package:linux-x64 && npm run package:linux-arm64 && npm run package:win32-x64 && npm run package:win32-arm64 && npm run package:darwin-x64 && npm run package:darwin-arm64",
        "vscode:prepublish": "npm run build:extension"
    },
    "dependencies": {
        "vscode-languageclient": "^9.0.1"
    },
    "devDependencies": {
        "@types/node": "^20.19.33",
        "@types/vscode": "^1.84.0",
        "@vscode/vsce": "^3.2.0",
        "esbuild": "^0.25.0",
        "typescript": "^5.4.5"
    }
}
