@using Dependinator.Core
@using Dependinator.Core.Shared
@using Dependinator.UI.Modeling
@using Dependinator.UI.Modeling.Commands
@using Dependinator.UI.Shared.CloudSync
@using Microsoft.JSInterop

@inject ICanvasService canvasService
@inject IAppCloudSyncService appCloudSyncService
@inject ISnackbar snackbar
@inject Dependinator.UI.Modeling.Models.IModelMgr modelMgr
@inject ICommandService commandService
@inject IApplicationEvents applicationEvents
@inject IModelListService modelListService
@inject IConfigService configService
@inject IModelService modelService
@inject IDialogService dialogService
@inject IJSInterop jsInterop
@inject IVsCodeSendService vsCodeSendService
@inject Dependinator.UI.Diagrams.Interaction.INoteService noteService
@inject Dependinator.UI.Diagrams.Interaction.IManualEditService manualEditService
@implements IDisposable

<MudButtonGroup Color="Color.Tertiary" Size="Size.Small" Variant="Variant.Text" Style="@CssPosition">
    <MudTooltip Text="Menu">
        <MudMenu Icon="@Icons.Material.Outlined.Menu" IconColor="Color.Tertiary" Dense="true"
                 AnchorOrigin="Origin.BottomCenter" PopoverClass="dep-light-menu" data-testid="appbar-menu">
            <MudMenuItem IconColor="Color.Secondary" Icon="@Icons.Material.Outlined.Search" OnClick="OpenSearchAsync"
                         data-testid="menu-search">
                Search …
            </MudMenuItem>

            <MudMenuItem IconColor="Color.Secondary" Icon="@Icons.Material.Outlined.FitScreen"
                         OnClick="canvasService.PanZoomToFit" data-testid="menu-fit-to-screen">
                Fit to Screen
            </MudMenuItem>

            <MudDivider />

            <MudMenu Label="Edit" PopoverClass="dep-light-menu" data-testid="menu-edit">
                <MudText Typo="Typo.caption" Class="px-4 py-1 mud-text-secondary">History</MudText>
                <MudMenuItem IconColor="Color.Secondary" Icon="@Icons.Material.Outlined.Undo"
                             Disabled="@(!commandService.CanUndo)" OnClick="commandService.Undo" data-testid="menu-undo">
                    Undo
                </MudMenuItem>

                <MudMenuItem IconColor="Color.Secondary" Icon="@Icons.Material.Outlined.Redo"
                             Disabled="@(!commandService.CanRedo)" OnClick="commandService.Redo" data-testid="menu-redo">
                    Redo
                </MudMenuItem>

                <MudText Typo="Typo.caption" Class="px-4 py-1 mud-text-secondary">Insert</MudText>
                <MudMenuItem IconColor="Color.Secondary" Icon="@Icons.Material.Outlined.AddBox" OnClick="BeginAddNode"
                             data-testid="menu-add-node">
                    Add Node …
                </MudMenuItem>

                <MudMenuItem IconColor="Color.Secondary" Icon="@Icons.Material.Outlined.StickyNote2"
                             OnClick="BeginAddNote" data-testid="menu-add-note">
                    Add Note …
                </MudMenuItem>

                <MudDivider />

                <MudMenuItem IconColor="Color.Secondary" Icon="@EditModeIcon" OnClick="ToggleEditMode"
                             data-testid="menu-edit-mode">
                    Edit Mode
                </MudMenuItem>

            </MudMenu>

            <MudMenu Label="View" PopoverClass="dep-light-menu" data-testid="menu-view">
                <MudMenuItem IconColor="Color.Secondary" Icon="@ShowHiddenNodesIcon" OnClick="ToggleShowHiddenNodes"
                             data-testid="menu-show-hidden-nodes">
                    Show Hidden Nodes
                </MudMenuItem>

                <MudMenuItem IconColor="Color.Secondary" Icon="@NotesSidebarIcon" OnClick="noteService.ToggleSidebar"
                             data-testid="menu-notes-sidebar">
                    Notes Sidebar
                </MudMenuItem>

                @if (!Build.IsVsCodeExtWasm)
                {
                    <MudDivider />

                    <MudMenuItem IconColor="Color.Secondary" Icon="@Icons.Material.Outlined.Refresh"
                                 OnClick="ReloadPageAsync" data-testid="menu-reload">
                        Reload
                    </MudMenuItem>
                }
            </MudMenu>

            <MudMenu Label="Models" PopoverClass="dep-light-menu" data-testid="menu-models">
                <MudText Typo="Typo.caption" Class="px-4 py-1 mud-text-secondary">Models</MudText>
                @{
                    IReadOnlyList<ModelItem> modelItems = modelListService.GetModelItems();
                }
                @foreach (ModelItem item in modelItems)
                {
                    bool isCurrent = IsCurrentModel(item);
                    <MudMenuItem IconColor="@GetMenuItemIconColor(isCurrent)" Icon="@GetModelItemIcon(item)"
                                 Style="@GetCurrentItemStyle(isCurrent)" title="@GetModelItemTitle(item)"
                                 OnClick="() => LoadModelItemAsync(item)" data-testid="menu-model-item">
                        @item.DisplayName
                    </MudMenuItem>
                }
                @if (modelItems.Count == 0)
                {
                    <MudMenuItem Disabled="true">No models</MudMenuItem>
                }

                <MudDivider />

                <MudMenuItem IconColor="Color.Secondary" Icon="@Icons.Material.Outlined.AddBox"
                             OnClick="NewModelAsync" data-testid="menu-new-model">
                    New Model …
                </MudMenuItem>

                @if (CanParseCurrentModel)
                {
                    <MudMenuItem IconColor="Color.Secondary" Icon="@Icons.Material.Outlined.Autorenew"
                                 OnClick="canvasService.RefreshAsync" data-testid="menu-parse">
                        Parse
                    </MudMenuItem>
                }

                <MudMenuItem IconColor="Color.Error" Icon="@Icons.Material.Outlined.DeveloperBoardOff"
                             OnClick="OnRemove" data-testid="menu-reset-model">
                    Reset Model
                </MudMenuItem>

                @if (appCloudSyncService.IsAvailable)
                {
                    <MudDivider />

                    <MudText Typo="Typo.caption" Class="px-4 py-1 mud-text-secondary">Device Sync</MudText>
                    @if (AuthState.IsAuthenticated)
                    {
                        <MudMenuItem IconColor="Color.Secondary" Icon="@Icons.Material.Outlined.CloudOff" OnClick="LogoutAsync"
                                     data-testid="menu-logout">
                            Disable Device Sync
                        </MudMenuItem>
                    }
                    else
                    {
                        <MudMenuItem IconColor="Color.Secondary" Icon="@Icons.Material.Outlined.CloudSync" OnClick="LoginAsync"
                                     data-testid="menu-login">
                            Enable Device Sync
                        </MudMenuItem>
                    }
                }
            </MudMenu>

            <MudDivider />

            <MudMenu Label="Help" PopoverClass="dep-light-menu" data-testid="menu-help-group">
                <MudMenuItem IconColor="Color.Secondary" Icon="@Icons.Material.Outlined.Help" OnClick="ShowHelpAsync"
                             data-testid="menu-help">
                    Help
                </MudMenuItem>
                <MudMenuItem IconColor="Color.Secondary" Icon="@Icons.Material.Outlined.Info" OnClick="ShowAbout"
                             data-testid="menu-about">
                    About
                </MudMenuItem>
            </MudMenu>
        </MudMenu>
    </MudTooltip>

    <MudTooltip>
        <TooltipContent>
            <div>@CloudStatusText</div>
            <div>@SyncStatusText</div>
        </TooltipContent>
        <ChildContent>
            <span>
                <MudIconButton Icon="@CurrentCloudIconInfo.Icon" Color="@CurrentCloudIconInfo.Color"
                               Class="@(IsCloudConnecting ? "cloud-connecting" : null)"
                               Disabled="@(!appCloudSyncService.IsAvailable)" OnClick="ToggleCloudAuthAsync"
                               data-testid="toolbar-cloud" />
            </span>
        </ChildContent>
    </MudTooltip>

    <MudTooltip Text="Search (Ctrl+F)">
        <MudIconButton Icon="@Icons.Material.Outlined.Search" OnClick="OpenSearchAsync" data-testid="toolbar-search" />
    </MudTooltip>

    <MudHidden Breakpoint="Breakpoint.SmAndDown">
        <MudTooltip Text="Undo">
            <MudIconButton Icon="@Icons.Material.Outlined.Undo" Color="@GetToolbarButtonColor(commandService.CanUndo)"
                           OnClick="commandService.Undo" data-testid="toolbar-undo" />
        </MudTooltip>
        <MudTooltip Text="Redo">
            <MudIconButton Icon="@Icons.Material.Outlined.Redo" Color="@GetToolbarButtonColor(commandService.CanRedo)"
                           OnClick="commandService.Redo" data-testid="toolbar-redo" />
        </MudTooltip>
        @if (CanParseCurrentModel)
        {
            <MudTooltip Text="Parse">
                <MudIconButton Icon="@Icons.Material.Outlined.Autorenew" OnClick="canvasService.RefreshAsync"
                               data-testid="toolbar-parse" />
            </MudTooltip>
        }
        @if (ViewOptions.IsEditingEnabled)
        {
            <MudTooltip Text="Disable edit mode">
                <MudIconButton Icon="@MudBlazor.Icons.Material.Filled.Edit" Color="@Color.Warning" OnClick="ToggleEditMode"
                               data-testid="toolbar-edit" />
            </MudTooltip>
        }
        else
        {
            <MudTooltip Text="Enable edit mode">
                <MudIconButton Icon="@MudBlazor.Icons.Material.Outlined.Edit" Color="@Color.Tertiary"
                               OnClick="ToggleEditMode" data-testid="toolbar-edit" />
            </MudTooltip>
        }
        <MudTooltip Text="Help">
            <MudIconButton Icon="@Icons.Material.Outlined.Help" OnClick="ShowHelpAsync" data-testid="toolbar-help" />
        </MudTooltip>
    </MudHidden>

</MudButtonGroup>

<MudMessageBox @ref="resetWarningBox" Title="Reset Model" CancelText="Cancel">
    <MessageContent>
        <MudText>Do you want to reset model?</MudText>
        <MudText Typo="Typo.body2">Note: Layout of all nodes and sub-nodes will be reset.</MudText>
    </MessageContent>
    <YesButton>
        <MudButton Variant="Variant.Filled" Color="Color.Error" StartIcon="@Icons.Material.Filled.DeveloperBoardOff">
            Reset
        </MudButton>
    </YesButton>
</MudMessageBox>

<MudMessageBox @ref="aboutBox" Title="About Dependinator" YesText="Close">
    <MessageContent>
        <MudText Typo="Typo.body1">Version: @Build.Version</MudText>
        <MudText Typo="Typo.body1">Commit: @Build.CommitSid</MudText>
        <MudText Typo="Typo.body1">Build Time: @Build.Time</MudText>
    </MessageContent>
</MudMessageBox>

<MudMessageBox @ref="syncDownBox" Title="Replace Local Cached Model" CancelText="Cancel">
    <MessageContent>
        <MudText>@SyncDownPrompt</MudText>
        <MudText Typo="Typo.body2">@SyncDownPromptDetail</MudText>
    </MessageContent>
    <YesButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.CloudDownload">
            Replace
        </MudButton>
    </YesButton>
</MudMessageBox>

<MudMessageBox @ref="syncConflictBox" Title="Sync Conflict" YesText="Use Cloud" NoText="Keep Local" CancelText="Cancel">
    <MessageContent>
        <MudText>Both local and cloud copies changed since last sync.</MudText>
        <MudText Typo="Typo.body2">Choose which copy should win.</MudText>
    </MessageContent>
</MudMessageBox>

@code {
    MudMessageBox resetWarningBox { get; set; } = null!;
    MudMessageBox aboutBox { get; set; } = null!;
    MudMessageBox syncDownBox { get; set; } = null!;
    MudMessageBox syncConflictBox { get; set; } = null!;

    DotNetObjectReference<AppBar>? selfReference;
    bool isSearchOpen;

    record CloudIconInfo(string Icon, MudBlazor.Color Color);
    static readonly CloudIconInfo NotAvailable = new(Icons.Material.Outlined.CloudOff, Color.Tertiary);
    static readonly CloudIconInfo Connecting = new(Icons.Material.Outlined.CloudSync, Color.Info);
    static readonly CloudIconInfo NotAuthenticated = new(Icons.Material.Outlined.CloudQueue, Color.Tertiary);
    static readonly CloudIconInfo HasLocalChanges = new(Icons.Material.Outlined.CloudUpload, Color.Info);
    static readonly CloudIconInfo HasRemoteChanges = new(Icons.Material.Outlined.CloudDownload, Color.Info);
    static readonly CloudIconInfo HasConflicts = new(Icons.Material.Outlined.SyncProblem, Color.Error);
    static readonly CloudIconInfo IsSynced = new(Icons.Material.Filled.CloudDone, Color.Success);

    string? CurrentRecentModelPath =>
    modelListService.RecentModelPaths.Count > 0 ? modelListService.RecentModelPaths[0] : null;
    string? CurrentCloudModelPath => appCloudSyncService.CurrentNormalizedModelPath;
    global::Shared.CloudAuthState AuthState => appCloudSyncService.AuthState;
    CloudSyncState CurrentCloudSyncState => appCloudSyncService.GetCloudSyncState();
    bool IsCloudConnecting => appCloudSyncService.IsConnecting;
    CloudIconInfo CurrentCloudIconInfo => IsCloudConnecting ? Connecting : GetCloudIconInfo(CurrentCloudSyncState);
    bool HasSyncConflicts => CurrentCloudSyncState is CloudSyncState.HasConflicts;
    CloudSyncState previousCloudSyncState = CloudSyncState.NotAvailable;
    string CssPosition =>
    $"position:fixed;left:{15}px; top:{3}px;"
    + "background:rgba(255,255,255,0.9);border-radius:4px;"
    + "box-shadow:var(--mud-elevation-2);";
    string CloudStatusText =>
    !appCloudSyncService.IsAvailable
    ? "Cloud sync unavailable"
                : IsCloudConnecting
    ? "Connecting to cloud …"
                : AuthState.IsAuthenticated
    ? $"Device sync enabled for {AuthState.User?.Email ?? AuthState.User?.UserId}"
    : "Device sync disabled, click to enable";
    string SyncDownPrompt =>
    HasSyncConflicts
    ? "Download the cloud copy and overwrite the local cached model and unsynced local changes?"
                : "Download the cloud copy and overwrite the local cached model?";
    string SyncDownPromptDetail =>
    HasSyncConflicts
    ? "Both the local cached model and the cloud copy have changed since the last sync."
                : "The current local cached layout data will be replaced.";
    string SyncStatusText => "";

    protected override void OnInitialized()
    {
        base.OnInitialized();

        applicationEvents.UIStateChanged += OnUiStateChanged;
        appCloudSyncService.Changed += OnUiStateChanged;
        appCloudSyncService.BackgroundSyncError += OnBackgroundSyncError;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await base.OnAfterRenderAsync(firstRender);

        if (!firstRender)
            return;

        selfReference = jsInterop.Reference(this);
        await jsInterop.Call("listenToKeyDown", selfReference, nameof(OnSearchHotkey));
    }

    [JSInvokable]
    public ValueTask OnSearchHotkey()
    {
        _ = InvokeAsync(OpenSearchAsync);
        return ValueTask.CompletedTask;
    }

    async Task OpenSearchAsync()
    {
        if (isSearchOpen)
            return;

        isSearchOpen = true;
        try
        {
            var options = new DialogOptions
            {
                CloseOnEscapeKey = true,
                NoHeader = true,
                Position = DialogPosition.TopCenter,
                MaxWidth = MaxWidth.Small,
                FullWidth = true,
            };
            var dialog = await dialogService.ShowAsync<Dependinator.UI.Diagrams.SearchDialog>(null, options);
            await dialog.Result;
        }
        finally
        {
            isSearchOpen = false;
        }
    }

    static CloudIconInfo GetCloudIconInfo(CloudSyncState state) => state switch
    {
        CloudSyncState.NotAvailable => NotAvailable,
        CloudSyncState.NotAuthenticated => NotAuthenticated,
        CloudSyncState.HasLocalChanges => HasLocalChanges,
        CloudSyncState.HasRemoteChanges => HasRemoteChanges,
        CloudSyncState.HasConflicts => HasConflicts,
        CloudSyncState.IsSynced => IsSynced,
        _ => NotAvailable
    };

    public void Dispose()
    {
        applicationEvents.UIStateChanged -= OnUiStateChanged;
        appCloudSyncService.Changed -= OnUiStateChanged;
        appCloudSyncService.BackgroundSyncError -= OnBackgroundSyncError;
        selfReference?.Dispose();
    }

    async Task ToggleCloudAuthAsync()
    {
        // Ignore clicks while the initial auth state is still being determined.
        if (IsCloudConnecting)
            return;

        switch (CurrentCloudSyncState)
        {
            case CloudSyncState.NotAvailable:
            case CloudSyncState.IsSynced:
                return;
            case CloudSyncState.NotAuthenticated:
                await LoginAsync();
                return;
            case CloudSyncState.HasLocalChanges:
                await SyncUpAsync();
                return;
            case CloudSyncState.HasRemoteChanges:
                await SyncDownAsync();
                return;
            case CloudSyncState.HasConflicts:
                await ResolveConflictAsync();
                return;
        }
    }

    async Task LoginAsync()
    {
        if (!Try(out var error, await appCloudSyncService.LoginAsync()))
        {
            snackbar.Add(error.ErrorMessage, Severity.Error);
            return;
        }

        snackbar.Add("Device sync is enabled.", Severity.Success);
    }

    async Task SyncUpAsync()
    {
        if (!Try(out _, out var error, await appCloudSyncService.SyncUpAsync()))
        {
            snackbar.Add(error.ErrorMessage, Severity.Error);
            return;
        }
    }

    async Task LogoutAsync()
    {
        if (!Try(out var error, await appCloudSyncService.LogoutAsync()))
        {
            snackbar.Add(error.ErrorMessage, Severity.Error);
            return;
        }

        snackbar.Add("Device sync is disabled.", Severity.Info);
    }

    async Task ResolveConflictAsync()
    {
        bool? selection = await syncConflictBox.ShowAsync();
        if (selection is true)
        {
            await SyncDownAsync(skipConfirmation: true);
            return;
        }

        if (selection is false)
            await SyncUpAsync();
    }

    async Task SyncDownAsync(bool skipConfirmation = false)
    {
        if (!skipConfirmation && await syncDownBox.ShowAsync() != true)
            return;

        if (string.IsNullOrWhiteSpace(modelMgr.ModelPath))
        {
            snackbar.Add("Model is not loaded.", Severity.Warning);
            return;
        }

        R<ModelInfo> syncDownResult = await appCloudSyncService.SyncDownAsync();
        if (syncDownResult.IsNone)
        {
            snackbar.Add("No cloud model existed, so the local model was uploaded instead.", Severity.Info);
            return;
        }

        if (!Try(out var modelInfo, out var error, syncDownResult))
        {
            snackbar.Add(error.ErrorMessage, Severity.Error);
            return;
        }

        snackbar.Add($"Loaded cloud model for {Path.GetFileNameWithoutExtension(modelInfo.Path)}.", Severity.Success);
    }

    async Task LoadCloudModelAsync(global::Shared.CloudModelMetadata cloudModel)
    {
        if (!Try(out _, out var error, await appCloudSyncService.LoadCloudModelAsync(cloudModel)))
        {
            snackbar.Add(error.ErrorMessage, Severity.Error);
            return;
        }

        snackbar.Add(
        $"Loaded cloud model for {Path.GetFileNameWithoutExtension(cloudModel.NormalizedPath)}.",
        Severity.Success
        );
    }

    async Task OnRemove()
    {
        if (await resetWarningBox.ShowAsync() != true)
            return;

        await canvasService.RemoveAsync();
    }

    void BeginAddNote()
    {
        noteService.BeginPlaceNote();
        snackbar.Add("Click on the diagram to place the note.", Severity.Info);
    }

    void BeginAddNode()
    {
        manualEditService.BeginPlaceNode();
        snackbar.Add("Click on the diagram to place the node.", Severity.Info);
    }

    bool CanParseCurrentModel =>
    (Build.IsVsCodeExtWasm || Build.IsWeb) && ModelPaths.IsParseable(modelMgr.ModelPath);

    async Task NewModelAsync()
    {
        List<string> existingPaths = modelListService.GetModelItems().Select(item => item.Path).ToList();
        var parameters = new DialogParameters<NewModelDialog> { { d => d.ExistingPaths, existingPaths } };
        var dialog = await dialogService.ShowAsync<NewModelDialog>("New Model", parameters);
        var result = await dialog.Result;
        if (result is null || result.Canceled)
            return;

        string name = (string)result.Data!;

        // A new empty model is only useful with editing enabled; opening an existing
        // design model later leaves the toggle as the user last set it.
        ViewOptions.SetIsEditingEnabled(true);
        await canvasService.LoadAsync(name);
        snackbar.Add("Empty model created. Use Edit > Add Node or double-click the canvas to add nodes.",
        Severity.Info);
        applicationEvents.TriggerUIStateChanged();
    }

    async Task ReloadPageAsync() => await jsInterop.Call("reloadPage");

    Task ShowAbout() => aboutBox.ShowAsync();

    Task ShowHelpAsync() => vsCodeSendService.OpenHelpAsync();

    void OnUiStateChanged() => _ = InvokeAsync(HandleUiStateChangedAsync);

    Task HandleUiStateChangedAsync()
    {
        CloudSyncState currentCloudSyncState = CurrentCloudSyncState;
        if (
        currentCloudSyncState is CloudSyncState.HasConflicts
        && previousCloudSyncState is not CloudSyncState.HasConflicts
        )
        {
            ShowSyncConflictSnackbar();
        }

        previousCloudSyncState = currentCloudSyncState;
        StateHasChanged();
        return Task.CompletedTask;
    }

    void ShowSyncConflictSnackbar()
    {
        snackbar.Add(
        "Cloud sync conflict detected.",
        Severity.Error,
        options =>
        {
            options.Action = "Resolve";
            options.RequireInteraction = true;
            options.OnClick = _ => InvokeAsync(ToggleCloudAuthAsync);
        },
        key: "cloud-sync-conflict"
                );
    }

    void OnBackgroundSyncError(string errorMessage)
    {
        _ = InvokeAsync(() => snackbar.Add(errorMessage, Severity.Warning));
    }

    string ShowHiddenNodesIcon => ViewOptions.ShowHiddenNodes
        ? Icons.Material.Filled.CheckCircle
        : Icons.Material.Outlined.Circle;

    string EditModeIcon => ViewOptions.IsEditingEnabled
        ? Icons.Material.Filled.CheckCircle
        : Icons.Material.Outlined.Circle;

    string NotesSidebarIcon => noteService.IsShowSidebar
        ? Icons.Material.Filled.CheckCircle
        : Icons.Material.Outlined.Circle;

    string EditModeToolbarIcon => ViewOptions.IsEditingEnabled
        ? Icons.Material.Filled.Edit
        : Icons.Material.Outlined.EditOff;

    MudBlazor.Color EditModeToolbarColor => ViewOptions.IsEditingEnabled
        ? Color.Default
        : Color.Inherit;

    void ToggleEditMode()
    {
        ViewOptions.SetIsEditingEnabled(!ViewOptions.IsEditingEnabled);
        // Edit-only markup (e.g. link handles) is baked into cached tiles, so the cache must be
        // cleared for the toggle to take effect immediately.
        modelService.ClearCache();
        applicationEvents.TriggerUIStateChanged();
    }

    async Task ToggleShowHiddenNodes()
    {
        var newValue = !ViewOptions.ShowHiddenNodes;
        ViewOptions.SetShowHiddenNodes(newValue);
        await configService.SetAsync(config => config.ShowHiddenNodes = newValue);
        modelService.ClearCache();
        applicationEvents.TriggerUIStateChanged();
    }

    static MudBlazor.Color GetMenuItemIconColor(bool isCurrent) => isCurrent ? Color.Secondary : Color.Default;
    static MudBlazor.Color GetToolbarButtonColor(bool isEnabled) => isEnabled ? Color.Tertiary : Color.Default;

    static string? GetCurrentItemStyle(bool isCurrent) => isCurrent ? "color: var(--mud-palette-primary);" : null;

    static string GetModelItemIcon(ModelItem item) =>
    item switch
    {
        { IsLocal: true, IsCloud: true } => Icons.Material.Outlined.CloudDone,
        { IsCloud: true } => Icons.Material.Outlined.CloudDownload,
        _ when ModelPaths.IsDesignModel(item.Path) => Icons.Material.Outlined.DesignServices,
        _ => Icons.Material.Outlined.Schema,
    };

    static string GetModelItemTitle(ModelItem item)
    {
        string source = item switch
        {
            { IsLocal: true, IsCloud: true } => "Local + cloud",
            { IsCloud: true } => "Cloud",
            _ when ModelPaths.IsDesignModel(item.Path) => "Design",
            _ => "Local",
        };
        return $"{item.Path} ({source})";
    }

    async Task LoadModelItemAsync(ModelItem item)
    {
        if (item.IsLocal)
        {
            await canvasService.LoadAsync(item.Path);
            return;
        }

        await LoadCloudModelAsync(item.CloudModel!);
    }

    bool IsCurrentModel(ModelItem item) =>
    string.Equals(item.Path, CurrentRecentModelPath, StringComparison.Ordinal)
    || (
    item.IsCloud
    && string.Equals(
    item.CloudModel!.NormalizedPath,
    CurrentCloudModelPath,
    StringComparison.OrdinalIgnoreCase
    )
    );

    static string GetSyncStatusDescription(CloudSyncState state) =>
    state switch
    {
        CloudSyncState.HasConflicts => "local and remote changes conflict",
        CloudSyncState.HasLocalChanges => "local changes pending upload",
        CloudSyncState.HasRemoteChanges => "remote changes pending download",
        _ => "in sync",
    };
}