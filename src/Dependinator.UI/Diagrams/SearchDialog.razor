@using Dependinator.UI.Modeling.Models
@implements IDisposable
@inject INodeSearchService searchService
@inject INavigationService navigationService
@inject IApplicationEvents applicationEvents

<MudDialog Class="search-dialog" ContentClass="pa-2" Style="margin-top:-29px;">
  <DialogContent>
    <MudTextField @ref="textField" T="string" Value="@query" ValueChanged="OnQueryChanged" Immediate="true"
                  Autofocus="true" Placeholder="Search nodes…" Variant="Variant.Outlined" Margin="Margin.Dense"
                  Adornment="Adornment.Start" AdornmentIcon="@MudBlazor.Icons.Material.Outlined.Search" Clearable="true"
                  FullWidth="true" Class="search-dialog__field" OnKeyDown="OnKeyDown" autocomplete="off" />

    @if (results.Count > 0)
    {
      <div class="search-dialog__results">
        @for (int i = 0; i < results.Count; i++)
        {
          var index = i;
          var result = results[index];
          <div class="search-dialog__item @(index == selectedIndex ? "search-dialog__item--selected" : "")"
               @onclick="() => SelectAsync(result)">
            <span class="search-dialog__short">@result.ShortName</span>
            <span class="search-dialog__full">@result.FullName</span>
            <span class="search-dialog__nav" title="Go to node (keep dialog open)"
                  @onclick="() => NavigateAsync(result)" @onclick:stopPropagation="true">
              <MudIcon Icon="@MudBlazor.Icons.Material.Outlined.MyLocation" Size="Size.Small" />
            </span>
          </div>
        }
      </div>
    }
    else if (!string.IsNullOrWhiteSpace(query))
    {
      <MudText Typo="Typo.body2" Class="search-dialog__empty">No matching nodes</MudText>
    }
  </DialogContent>
</MudDialog>

@code {
  [CascadingParameter]
  IMudDialogInstance MudDialog { get; set; } = null!;

  MudTextField<string> textField = null!;
  string query = "";
  IReadOnlyList<NodeSearchResult> results = [];
  int selectedIndex = 0;
  bool isDisposed;

  protected override void OnInitialized() => applicationEvents.ModelChanged += OnModelChanged;

  protected override async Task OnAfterRenderAsync(bool firstRender)
  {
    if (!firstRender)
      return;

    // Autofocus handles the common case; this is a fallback for when the dialog's
    // open animation steals/delays focus. The small delay lets the transition settle.
    await Task.Delay(50);

    // If the dialog was closed during the delay (e.g. dismissed quickly, or the page is
    // tearing down at the end of a test), the element is gone — focusing it would make
    // MudInput log "Unable to focus an invalid element". Skip it.
    if (isDisposed)
      return;

    await textField.FocusAsync();
  }

  public void Dispose()
  {
    applicationEvents.ModelChanged -= OnModelChanged;
    isDisposed = true;
  }

  void OnQueryChanged(string value)
  {
    query = value ?? "";
    results = searchService.Search(query);
    selectedIndex = 0;
  }

  // The query only runs on input, so a query typed while the model is still being parsed
  // (or before a background refresh lands) would show stale — often empty — results until
  // the user types again. Re-run it whenever the model changes; keep the selection on the
  // same position when possible so arrow-key browsing isn't reset by background updates.
  void OnModelChanged() =>
    InvokeAsync(() =>
    {
      if (isDisposed || string.IsNullOrWhiteSpace(query))
        return;

      results = searchService.Search(query);
      selectedIndex = Math.Min(selectedIndex, Math.Max(0, results.Count - 1));
      StateHasChanged();
    });

  async Task OnKeyDown(KeyboardEventArgs e)
  {
    switch (e.Key)
    {
      case "ArrowDown":
        if (results.Count > 0)
          selectedIndex = Math.Min(selectedIndex + 1, results.Count - 1);
        break;
      case "ArrowUp":
        if (results.Count > 0)
          selectedIndex = Math.Max(selectedIndex - 1, 0);
        break;
      case "Enter":
        if (selectedIndex >= 0 && selectedIndex < results.Count)
          await SelectAsync(results[selectedIndex]);
        break;
      case "Escape":
        MudDialog.Close(DialogResult.Cancel());
        break;
    }
  }

  async Task SelectAsync(NodeSearchResult result)
  {
    MudDialog.Close(DialogResult.Ok(true));
    await navigationService.ShowNodeAsync(result.Id);
  }

  // Navigate to the node but keep the dialog open so the user can keep exploring.
  async Task NavigateAsync(NodeSearchResult result)
  {
    await navigationService.ShowNodeAsync(result.Id);
    await textField.FocusAsync();
  }
}
