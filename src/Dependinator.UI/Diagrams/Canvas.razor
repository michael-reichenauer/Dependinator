@using Dependinator.UI.App
@using Dependinator.UI.Diagrams.Dependencies
@using Microsoft.AspNetCore.Components.Forms

<AppBar />
<NodeToolbar />
<LineToolbar />
<ManualNodeNameEntry />
<ContextMenu />
<DependenciesTree />
<NotesSidebar />
<AppProgress />


<div @ref="dropZoneElement" class="drop-zone">
    <InputFile id="inputfile" hidden="true" OnChange="LoadFiles" multiple @ref="inputFile" />

    <svg id="svgcanvas" @ref=@Ref xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink"
         width="@Width" height="@Height" viewBox="@ViewBox" style="background-color:@DColors.CanvasBackground">

        <style>
                    svg {
                        cursor:
                            @Cursor
                        ;
                    }

                    .hoverable:hover * {
                        stroke:
                            @DColors.Selected
                        ;
                        stroke-width: 2px;
                        stroke-opacity: 1;
                    }

                    .hoverableedit:hover * {
                        stroke:
                            @DColors.EditNodeBorder
                        ;
                        stroke-width: 4px;
                        stroke-opacity: 1;
                    }

                    .selectpoint:hover * {
                        fill: #51b8fc;
                        stroke-width: 1px;
                        fill-opacity: 0.3;
                    }

                    /* Drag-to-link handle: hidden until its node is hovered; pointer-events off
                       while hidden so it never steals presses or elementFromPoint hit tests. */
                    .linkhandle {
                        opacity: 0;
                        pointer-events: none;
                    }

                    .hoverable:hover .linkhandle {
                        opacity: 1;
                        pointer-events: all;
                        cursor: crosshair;
                    }

                    /* Cancel the generic hover stroke on the handle dot and touch ellipse (the
                       plus glyph path keeps its own white stroke). */
                    .hoverable:hover .linkhandle circle,
                    .hoverable:hover .linkhandle ellipse {
                        stroke: none;
                        stroke-width: 0;
                    }

                    .hoverable:hover .linkhandle path {
                        stroke: white;
                        stroke-width: 0.8px;
                    }

                    .iconName {
                        font-family: Verdana, Helvetica, Arial, sans-serif;
                        fill:
                            @DColors.Text
                        ;
                        dominant-baseline: hanging;
                        text-anchor: middle;
                        pointer-events: none;
                    }

                    .memberName {
                        font-family: Verdana, Helvetica, Arial, sans-serif;
                        fill:
                            @DColors.Text
                        ;
                        dominant-baseline: middle;
                        text-anchor: start;
                        pointer-events: none;
                    }

                    .nodeName {
                        font-family: Verdana, Helvetica, Arial, sans-serif;
                        fill:
                            @DColors.Text
                        ;
                        dominant-baseline: hanging;
                        text-anchor: start;
                        pointer-events: none;
                    }

                    .iconDescription {
                        font-family: Verdana, Helvetica, Arial, sans-serif;
                        font-style: italic;
                        fill:
                            @DColors.Text
                        ;
                        fill-opacity: 0.7;
                        text-anchor: middle;
                        pointer-events: none;
                    }

                    .memberDescription {
                        font-family: Verdana, Helvetica, Arial, sans-serif;
                        font-style: italic;
                        fill:
                            @DColors.Text
                        ;
                        fill-opacity: 0.7;
                        text-anchor: start;
                        pointer-events: none;
                    }

                    .nodeDescription {
                        font-family: Verdana, Helvetica, Arial, sans-serif;
                        font-style: italic;
                        fill:
                            @DColors.Text
                        ;
                        fill-opacity: 0.7;
                        text-anchor: start;
                        pointer-events: none;
                    }
        </style>
        <defs>
            <marker id="arrow-line" markerWidth="7" markerHeight="6" refX="7" refY="3" orient="auto">
                <polygon points="0 0, 7 3, 0 6" fill="@DColors.Line" />
            </marker>
            <marker id="arrow-hidden" markerWidth="7" markerHeight="6" refX="7" refY="3" orient="auto">
                <polygon points="0 0, 7 3, 0 6" fill="@DColors.LineHidden" />
            </marker>
            <marker id="arrow-direct" markerWidth="7" markerHeight="6" refX="7" refY="3" orient="auto">
                <polygon points="0 0, 7 3, 0 6" fill="@DColors.DirectLine" />
            </marker>
            @((MarkupString)IconDefs)
        </defs>
        @((MarkupString)Content)
    </svg>

    @if (manualEditService.IsLinkDragActive)
    {
        <svg class="link-drag-overlay" xmlns="http://www.w3.org/2000/svg">
            <line x1="@Px(manualEditService.LinkDragStart.X)" y1="@Px(manualEditService.LinkDragStart.Y)"
                  x2="@Px(manualEditService.LinkDragEnd.X)" y2="@Px(manualEditService.LinkDragEnd.Y)"
                  stroke="@DColors.Selected" stroke-width="1.5" stroke-dasharray="6,6" />
        </svg>
    }
</div>