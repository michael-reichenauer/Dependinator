@using Dependinator.UI.Diagrams.Dependencies
@using Dependinator.UI.Diagrams.Icons
@using Dependinator.UI.Diagrams.Svg
@using Dependinator.Core
@using Dependinator.Core.Parsing
@using Dependinator.Core.Shared
@using MudBlazor
@implements IDisposable

@if (HasSelectedLine)
{
  <MudButtonGroup Color="Color.Tertiary" Size="Size.Small" Variant="Variant.Text" Style="@CssPosition">
    <MudTooltip Text="Menu">
      <MudMenu Icon="@MudBlazor.Icons.Material.Outlined.Menu" Dense="true" AnchorOrigin="Origin.BottomCenter"
               PopoverClass="dep-light-menu" data-testid="node-menu">
        @* <MudMenuItem IconColor="Color.Secondary" Icon="@MudBlazor.Icons.Material.Outlined.TextSnippet"
                     OnClick="ShowProperties" data-testid="node-menu-properties">
          Properties …
        </MudMenuItem> *@
        <MudMenuItem IconColor="Color.Secondary" Icon="@MudBlazor.Icons.Material.Outlined.FormatShapes"
                     OnClick="LayoutChildren" data-testid="node-menu-reset-children">
          Reset Children Layout
        </MudMenuItem>
        <MudMenuItem IconColor="Color.Secondary" Icon="@MudBlazor.Icons.Material.Outlined.DeveloperBoardOff"
                     OnClick="LayoutDescendants" data-testid="node-menu-reset-descendants">
          Reset All Descendants Layout
        </MudMenuItem>
        <MudMenuItem IconColor="Color.Secondary" Icon="@MudBlazor.Icons.Material.Outlined.EmojiSymbols"
                     OnClick="SelectIconAsync" data-testid="node-menu-set-icon">
          Set Icon …
        </MudMenuItem>

        @if (IsSelectedNodeManual)
        {
          <MudMenuItem IconColor="Color.Error" Icon="@MudBlazor.Icons.Material.Outlined.Delete"
                       OnClick="DeleteNode" data-testid="node-menu-delete">
            Delete Node
          </MudMenuItem>
        }

        <MudDivider />
        @if (!IsNodeHidden)
        {
          <MudMenuItem IconColor="Color.Secondary" Icon="@MudBlazor.Icons.Material.Outlined.VisibilityOff"
                       OnClick="ToggleNodeHide" Disabled="@IsVisibilityDisabled" data-testid="node-menu-toggle-hide">
            Hide Node …
          </MudMenuItem>
        }
        else
        {
          <MudMenuItem IconColor="Color.Secondary" Icon="@MudBlazor.Icons.Material.Outlined.Visibility"
                       OnClick="ToggleNodeHide" Disabled="@IsVisibilityDisabled" data-testid="node-menu-toggle-hide">
            Show Node …
          </MudMenuItem>
        }
      </MudMenu>
    </MudTooltip>

    <MudTooltip Text="Show references">
      <MudIconButton Icon="@Icon.ReferencesIcon" OnClick="ShowReferences" data-testid="node-references" />
    </MudTooltip>
    <MudTooltip Text="Show dependencies">
      <MudIconButton Icon="@Icon.DependenciesIcon" OnClick="ShowDependencies" data-testid="node-dependencies" />
    </MudTooltip>

    @if (NodeSvg.IsEditingEnabled)
    {
      <MudTooltip Text="Decrease node size">
        <MudIconButton Icon="@MudBlazor.Icons.Material.Filled.CloseFullscreen" OnClick="interactionService.DecreaseNodeSize"
                       data-testid="node-decrease-size" />
      </MudTooltip>
      <MudTooltip Text="Increase node size">
        <MudIconButton Icon="@MudBlazor.Icons.Material.Filled.OpenInFull" OnClick="interactionService.IncreaseNodeSize"
                       data-testid="node-increase-size" />
      </MudTooltip>
      <MudTooltip Text="Set icon">
        <MudIconButton Icon="@MudBlazor.Icons.Material.Outlined.EmojiSymbols" OnClick="SelectIconAsync"
                       data-testid="node-set-icon" />
      </MudTooltip>
      <MudTooltip Text="Add link from this node">
        <MudIconButton Icon="@MudBlazor.Icons.Material.Outlined.CallMade" OnClick="BeginAddLink"
                       data-testid="node-add-link" />
      </MudTooltip>
    }

    @if (CanShowSource)
    {
      <MudTooltip Text="Show source code">
        <MudIconButton Icon="@MudBlazor.Icons.Material.Outlined.Code" OnClick="ShowSourceAsync"
                       data-testid="node-show-source" />
      </MudTooltip>
    }

    @if (!IsIconMode)
    {
      @if (IsEditNodeMode)
      {
        <MudTooltip Text="Exit node edit mode">
          <MudIconButton Icon="@MudBlazor.Icons.Material.Filled.Edit" OnClick="() => IsEditNodeMode = false"
                         Color="@Color.Warning" data-testid="node-edit" />
        </MudTooltip>
        <MudTooltip Text="Fit node to screen">
          <MudIconButton Icon="@MudBlazor.Icons.Material.Outlined.FitScreen" OnClick="interactionService.NodePanZoomToFit"
                         data-testid="node-fit-to-screen" />
        </MudTooltip>
      }
      else
      {
        @if (NodeSvg.IsEditingEnabled)
        {
          <MudTooltip Text="Edit node">
            <MudIconButton Icon="@MudBlazor.Icons.Material.Outlined.Edit" OnClick="() => IsEditNodeMode = true"
                           data-testid="node-edit" />
          </MudTooltip>
        }
      }
    }
  </MudButtonGroup>
}

<MudMessageBox @ref="mbox" Title="Reset Descendants" CancelText="Cancel">
  <MessageContent>
    Do you want to reset layout of all children and their descendants?
  </MessageContent>
  <YesButton>
    <MudButton Variant="Variant.Filled" Color="Color.Error"
               StartIcon="@MudBlazor.Icons.Material.Filled.DeveloperBoardOff">
      Reset
    </MudButton>
  </YesButton>
</MudMessageBox>


@code {
  const double ToolbarOffset = 58;
  private MudMessageBox mbox { get; set; } = null!;


  bool IsEditNodeMode
  {
    get { return interactionService.IsEditNodeMode; }
    set
    {
      Log.Info("Set val", value);
      interactionService.IsEditNodeMode = value;
    }
  }

  [Inject]
  IApplicationEvents applicationEvents { get; set; } = null!;

  [Inject]
  IInteractionService interactionService { get; set; } = null!;

  [Inject]
  ISelectionService selectionService { get; set; } = null!;

  [Inject]
  IDialogService dialogService { get; set; } = null!;

  [Inject]
  IDependenciesService dependenciesService { get; set; } = null!;

  [Inject]
  INodeEditService nodeEditService { get; set; } = null!;

  [Inject]
  Modeling.IModelService modelService { get; set; } = null!;

  [Inject]
  Modeling.Models.IModelMgr modelMgr { get; set; } = null!;

  [Inject]
  INavigationService navigationService { get; set; } = null!;

  [Inject]
  IConfigService configService { get; set; } = null!;

  [Inject]
  IManualEditService manualEditService { get; set; } = null!;

  [Inject]
  ISnackbar snackbar { get; set; } = null!;


  bool IsVisibilityDisabled => selectionService.IsSelectedNodeParentHidden();
  bool IsNodeHidden => selectionService.IsSelectedNodeHidden();
  bool IsSelectedNodeManual
  {
    get
    {
      if (!selectionService.SelectedId.IsNode)
        return false;
      using var model = modelMgr.UseModel();
      return model.Nodes.TryGetValue(Modeling.Models.NodeId.FromId(selectionService.SelectedId.Id), out var node)
          && node.IsManual;
    }
  }
  bool HasSelectedLine => selectionService.SelectedNodePosition != Shared.Types.Pos.None;
  bool IsIconMode => !interactionService.IsContainer;
  bool CanShowSource => interactionService.CanShowSource;

  string CssPosition =>
      $"position:fixed;left:{selectionService.SelectedNodePosition.X}px;"
      + $"top:{selectionService.SelectedNodePosition.Y - ToolbarOffset}px;"
      + "background:rgba(255,255,255,0.9);border-radius:4px;"
      + "box-shadow:var(--mud-elevation-2);";

  protected override void OnInitialized() => applicationEvents.UIStateChanged += OnUiStateChanged;

  void OnUiStateChanged() => InvokeAsync(StateHasChanged);

  public void Dispose() => applicationEvents.UIStateChanged -= OnUiStateChanged;

  void ShowProperties() =>
      dialogService.ShowAsync<NodeProperties>("Node Properties", new DialogOptions { CloseOnEscapeKey = true });

  async Task LayoutChildren()
  {
    if (!selectionService.SelectedId.IsNode)
      return;
    var nodeId = Modeling.Models.NodeId.FromId(selectionService.SelectedId.Id);
    var isEdit = selectionService.IsEditMode;
    selectionService.Unselect();
    await modelService.LayoutNode(nodeId);
    selectionService.Select(nodeId);
    selectionService.SetEditMode(isEdit);
  }

  async Task LayoutDescendants()
  {
    if (!selectionService.SelectedId.IsNode)
      return;
    if (await mbox.ShowAsync() != true)
    {
      return;
    }
    var nodeId = Modeling.Models.NodeId.FromId(selectionService.SelectedId.Id);
    var isEdit = selectionService.IsEditMode;
    selectionService.Unselect();
    await modelService.LayoutNode(nodeId, true);
    selectionService.Select(nodeId);
    selectionService.SetEditMode(isEdit);
  }

  async Task SetLayoutDensityAsync(Modeling.NodeLayoutDensity density)
  {
    Modeling.NodeLayout.SetDensity(density);
    await configService.SetAsync(config => config.LayoutDensity = density);
    applicationEvents.TriggerUIStateChanged();
  }

  string DensityIcon(Modeling.NodeLayoutDensity density) =>
      Modeling.NodeLayout.Density == density
          ? MudBlazor.Icons.Material.Filled.CheckCircle
          : MudBlazor.Icons.Material.Outlined.Circle;

  void ShowReferences() => dependenciesService.ShowReferences();

  void ShowDependencies() => dependenciesService.ShowDependencies();


  async Task ShowSourceAsync()
  {
    if (!selectionService.SelectedId.IsNode)
      return;

    string selectedId = selectionService.SelectedId.Id;
    var nodeId = Modeling.Models.NodeId.FromId(selectedId);
    FileSpan? nodeFileSpan = null;

    string nodeTitle = selectedId;

    using (var model = modelMgr.UseModel())
    {
      if (model.Nodes.TryGetValue(nodeId, out var node))
      {
        nodeTitle = node.LongName;
        nodeFileSpan = node.FileSpanOrParentSpan;
      }
    }

   
    if (nodeFileSpan is not null && Build.IsVsCodeExtWasm)
    {
      await navigationService.ShowEditor(Modeling.Models.NodeId.FromId(selectionService.SelectedId.Id));
      return;
    }
  }

  void ToggleNodeHide() => selectionService.ToggleNodeHide();

  void BeginAddLink()
  {
    if (!selectionService.SelectedId.IsNode)
      return;
    manualEditService.BeginAddLink(Modeling.Models.NodeId.FromId(selectionService.SelectedId.Id));
    snackbar.Add("Click a target node to link to (Esc or click empty space to cancel).", Severity.Info);
  }

  void DeleteNode()
  {
    if (!selectionService.SelectedId.IsNode)
      return;
    var nodeId = Modeling.Models.NodeId.FromId(selectionService.SelectedId.Id);
    selectionService.Unselect();
    manualEditService.DeleteManualNode(nodeId);
  }

  async Task SelectIconAsync()
  {
    if (!selectionService.SelectedId.IsNode)
      return;

    var nodeId = Modeling.Models.NodeId.FromId(selectionService.SelectedId.Id);
    string? currentIconName = null;
    string defaultIconName = "";
    using (var model = modelMgr.UseModel())
    {
      if (!model.Nodes.TryGetValue(nodeId, out var node))
        return;
      currentIconName = node.CustomIconName;
      defaultIconName = Icon.GetIconName(node.Type);
    }

    var parameters = new DialogParameters
    {
      { nameof(IconSelectorDialog.NodeIdValue), nodeId.Value },
      { nameof(IconSelectorDialog.CurrentIconName), currentIconName },
      { nameof(IconSelectorDialog.DefaultIconName), defaultIconName },
    };
    var options = new DialogOptions
    {
      CloseOnEscapeKey = true,
      NoHeader = true,
      Position = DialogPosition.TopCenter,
      MaxWidth = MaxWidth.Small,
      FullWidth = true,
    };
    var dialog = await dialogService.ShowAsync<IconSelectorDialog>(null, parameters, options);
    await dialog.Result;
  }
}