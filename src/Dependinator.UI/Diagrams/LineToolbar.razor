@using Dependinator.UI.Diagrams.Icons
@using Dependinator.UI.Diagrams.Dependencies
@using Dependinator.Core


@inject IApplicationEvents applicationEvents
@inject IInteractionService interactionService
@inject ISelectionService selectionService
@inject IDialogService dialogService
@inject IDependenciesService dependenciesService
@inject ILineEditService lineEditService
@inject IManualEditService manualEditService
@inject INavigationService navigationService
@implements IDisposable

@if (HasSelectedLine)
{
    <MudStack Style="@containerPosition" Spacing="1">
        <MudButtonGroup Color="Color.Tertiary" Size="Size.Small" Variant="Variant.Text"
                        Style="background:rgba(255,255,255,0.9);border-radius:4px;box-shadow:var(--mud-elevation-2);">
            @if (selectionService.IsSelectedLineDirect)
            {
                <MudTooltip Text="Hide line">
                    <MudIconButton Icon="@MudBlazor.Icons.Material.Filled.Close" OnClick="CloseDirectLine"
                                   data-testid="line-close" />
                </MudTooltip>
                <MudTooltip Text="Go to source node">
                    <MudIconButton Icon="@Icon.LineSourceIcon" OnClick="PanToSource" data-testid="line-pan-source" />
                </MudTooltip>
                <MudTooltip Text="Go to target node">
                    <MudIconButton Icon="@Icon.LineTargetIcon" OnClick="PanToTarget" data-testid="line-pan-target" />
                </MudTooltip>
            }
            else
            {
                <MudTooltip Text="Show references">
                    <MudIconButton Icon="@Icon.ReferencesIcon" OnClick="ShowReferences" data-testid="line-references" />
                </MudTooltip>
                <MudTooltip Text="Show dependencies">
                    <MudIconButton Icon="@Icon.DependenciesIcon" OnClick="ShowDependencies" data-testid="line-dependencies" />
                </MudTooltip>
                <MudTooltip Text="Add line point">
                    <MudIconButton Icon="@MudBlazor.Icons.Material.Filled.Add" OnClick="AddSegmentPoint"
                                   data-testid="line-add-point" />
                </MudTooltip>
                <MudTooltip Text="Remove line point">
                    <MudIconButton Icon="@MudBlazor.Icons.Material.Filled.Remove" OnClick="RemoveSegmentPoint"
                                   data-testid="line-remove-point" />
                </MudTooltip>
                @if (IsSelectedLineManual)
                {
                    <MudTooltip Text="Delete link">
                        <MudIconButton Icon="@MudBlazor.Icons.Material.Outlined.Delete" Color="Color.Error"
                                       OnClick="DeleteManualLine" data-testid="line-delete" />
                    </MudTooltip>
                }
            }
            @if (interactionService.CanShowLineSource)
            {
                <MudTooltip Text="Show source node source code">
                    <MudIconButton Icon="@MudBlazor.Icons.Material.Outlined.Code" OnClick="ShowSourceAsync"
                                   data-testid="line-show-source" />
                </MudTooltip>
            }
        </MudButtonGroup>
    </MudStack>
}


@code {
    bool HasSelectedLine => selectionService.SelectedLinePosition != Shared.Types.Pos.None;

    double left => selectionService.SelectedLinePosition.X - 10;
    double top => selectionService.SelectedLinePosition.Y - 30;
    string containerPosition =>
        FormattableString.Invariant($"Position: fixed; left:{left:0.##}px; top:{top:0.##}px");

    void ShowReferences() => dependenciesService.ShowReferences();
    void ShowDependencies() => dependenciesService.ShowDependencies();
    async Task AddSegmentPoint()
    {
        if (!selectionService.SelectedId.IsLine)
            return;
        await lineEditService.AddSegmentPoint(
            Modeling.Models.LineId.FromId(selectionService.SelectedId.Id),
            selectionService.SelectedLineClickPosition
        );
    }
    async Task RemoveSegmentPoint()
    {
        if (!selectionService.SelectedId.IsLine)
            return;
        await lineEditService.RemoveSegmentPoint(
            Modeling.Models.LineId.FromId(selectionService.SelectedId.Id),
            selectionService.SelectedLineClickPosition
        );
    }
    // The line shows only user-drawn link(s), so it can be deleted (parsed links cannot).
    bool IsSelectedLineManual =>
        TryGetSelectedLine(out var line) && line.Links.Any() && line.Links.All(l => l.IsManual);

    void DeleteManualLine()
    {
        if (!selectionService.SelectedId.IsLine)
            return;
        var lineId = Modeling.Models.LineId.FromId(selectionService.SelectedId.Id);
        selectionService.Unselect();
        manualEditService.DeleteManualLine(lineId);
    }

    void CloseDirectLine()
    {
        if (!selectionService.SelectedId.IsLine)
            return;
        var lineId = Modeling.Models.LineId.FromId(selectionService.SelectedId.Id);
        dependenciesService.HideDirectLine(lineId);
    }
    void PanToSource()
    {
        if (!TryGetSelectedLine(out var line))
            return;
        SelectNode(line.Source);
    }

    async Task ShowSourceAsync()
    {
        if (!TryGetSelectedLine(out var line))
            return;
        if (Build.IsVsCodeExtWasm)
            await navigationService.ShowEditor(line.Source.Id);
    }

    void PanToTarget()
    {
        if (!TryGetSelectedLine(out var line))
            return;
        SelectNode(line.Target);
    }

    bool TryGetSelectedLine(out Modeling.Models.Line line)
    {
        line = null!;
        if (!selectionService.SelectedId.IsLine)
            return false;
        var lineId = Modeling.Models.LineId.FromId(selectionService.SelectedId.Id);
        var found = dependenciesService.TryGetLine(lineId, out line);
        return found && line is not null;
    }

    void SelectNode(Modeling.Models.Node node)
    {
        applicationEvents.TriggerUIStateChanged();
        dependenciesService.ShowNodeAsync(node.Id);
    }

    protected override void OnInitialized() => applicationEvents.UIStateChanged += OnUiStateChanged;

    void OnUiStateChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => applicationEvents.UIStateChanged -= OnUiStateChanged;
}